@model F1VacationSite.Models.Trip

@{
    ViewData["Title"] = "Резервация";
}

@if (Model.Race == null || Model.Hotel == null)
{
    <p class="text-danger">Грешка при зареждане на данните.</p>
    return;
}

<div class="container my-4" style="max-width:600px;">
    <div class="card border shadow-sm mb-3" style="border-radius:12px;">
        <div class="card-body">
            <h5 class="fw-semibold mb-3">@Model.Race!.Name</h5>

            <div class="d-flex justify-content-between py-2 border-bottom" style="font-size:14px;">
                <span class="text-muted">Писта</span>
                <span class="fw-medium">@Model.Race.Circuit</span>
            </div>
            <div class="d-flex justify-content-between py-2 border-bottom" style="font-size:14px;">
                <span class="text-muted">Дата</span>
                <span class="fw-medium">@Model.Race.StartDate.ToString("dd MMM") &ndash; @Model.Race.EndDate.ToString("dd MMM yyyy")</span>
            </div>
            <div class="d-flex justify-content-between py-2 border-bottom" style="font-size:14px;">
                <span class="text-muted">Хотел</span>
                <span class="fw-medium">@Model.Hotel!.Name</span>
            </div>
            <div class="d-flex justify-content-between py-2 border-bottom" style="font-size:14px;">
                <span class="text-muted">Категория</span>
                <span style="color:#f5a623;">@for (int i = 0; i < Model.Hotel.Stars; i++) {
                    <text>&#9733;</text>
                }
            </span>
        </div>
        <div class="d-flex justify-content-between py-2 border-bottom" style="font-size:14px;">
            <span class="text-muted">Нощувки</span>
            <span class="fw-medium">@Model.Nights</span>
        </div>
        <div class="d-flex justify-content-between py-2" style="font-size:14px;">
            <span class="text-muted">Обща цена</span>
            <span class="fw-bold" style="font-size:20px;color:#e10600;">@Model.Price.ToString("C0", new System.Globalization.CultureInfo("bg-BG"))</span>
        </div>
    </div>
</div>

<div class="card border shadow-sm" style="border-radius:12px;">
    <div class="card-body">
        <form asp-action="Create" asp-route-tripId="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="specialRequest" class="form-label" style="font-size:13px;font-weight:500;">Специални изисквания <span class="text-muted">(по желание)</span></label>
                <textarea id="specialRequest" name="specialRequest" class="form-control" rows="3"
                          placeholder="Пр. стая с изглед, ранен чекин..."></textarea>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger px-4">Потвърди резервацията</button>
                <a asp-controller="Trips" asp-action="Index" class="btn btn-outline-secondary">Назад</a>
            </div>
        </form>
    </div>
</div>
</div>