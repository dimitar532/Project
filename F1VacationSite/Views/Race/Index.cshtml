@model IEnumerable<F1VacationSite.Models.Race>

@{
    ViewData["Title"] = "Сезон 2026";
}

<div class="container my-4">
    <h4 class="fw-semibold mb-1">Сезон 2026</h4>
    <p class="text-muted mb-4" style="font-size:13px;">Всички 22 кръга от Формула 1 сезон 2026</p>

    <div class="card border shadow-sm" style="border-radius:12px;overflow:hidden;">
        <table class="table table-hover mb-0">
            <thead style="background:#15151e;">
                <tr>
                    <th style="color:rgba(255,255,255,0.6);font-size:11px;text-transform:uppercase;letter-spacing:1px;border:none;width:50px;">#</th>
                    <th style="color:rgba(255,255,255,0.6);font-size:11px;text-transform:uppercase;letter-spacing:1px;border:none;">Grand Prix</th>
                    <th style="color:rgba(255,255,255,0.6);font-size:11px;text-transform:uppercase;letter-spacing:1px;border:none;">Държава</th>
                    <th style="color:rgba(255,255,255,0.6);font-size:11px;text-transform:uppercase;letter-spacing:1px;border:none;">Дата</th>
                    <th style="border:none;"></th>
                </tr>
            </thead>
            <tbody>
                @{
                    int round = 1;
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="badge rounded-pill bg-light text-secondary">@round</span>
                        </td>
                        <td>
                            <div class="fw-semibold" style="font-size:14px;">@item.Name</div>
                            <div class="text-muted" style="font-size:12px;">@item.Circuit</div>
                        </td>
                        <td class="text-muted" style="font-size:13px;">@item.Country</td>
                        <td class="text-muted" style="font-size:13px;white-space:nowrap;">
                            @item.StartDate.ToString("dd MMM") &ndash; @item.EndDate.ToString("dd MMM yyyy")
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Детайли</a>
                        </td>
                    </tr>
                    round++;
                }
            </tbody>
        </table>
    </div>
</div>