@model F1VacationSite.Models.Trip

<div class="card border shadow-sm mb-3 d-flex flex-row" style="border-radius:12px;overflow:hidden;">
    <div class="d-flex align-items-center justify-content-center position-relative flex-shrink-0" style="width:220px;background:#1a1a2e;">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" alt="@Model.Race?.Name" style="width:100%;height:100%;object-fit:cover;" />
        }
        else
        {
            <span style="font-size:3rem;">&#127950;</span>
        }
        <span class="badge position-absolute top-0 start-0 m-2" style="background:#e10600;font-size:10px;letter-spacing:0.5px;">@Model.Race?.Country</span>
    </div>

    <div class="card-body d-flex flex-column justify-content-between">
        <div>
            <h5 class="fw-semibold mb-1" style="font-size:16px;">@Model.Race?.Name</h5>
            <p class="text-muted mb-2" style="font-size:12px;">&#128205; @Model.Race?.Circuit &middot; @Model.Race?.StartDate.ToString("dd MMM") &ndash; @Model.Race?.EndDate.ToString("dd MMM yyyy")</p>
            <div class="mb-2">
                <div style="color:#f5a623;font-size:13px;">
                    @for (int i = 0; i < (Model.Hotel?.Stars ?? 0); i++)
                    {
                        <text>&#9733;</text>
                    }
                </div>
                <div class="fw-medium" style="font-size:13px;">@Model.Hotel?.Name</div>
                <div class="text-muted" style="font-size:12px;">@Model.Hotel?.City</div>
            </div>
        </div>

        <div class="d-flex align-items-end justify-content-between pt-2 border-top">
            <div>
                <div class="text-muted" style="font-size:12px;">@Model.Nights нощувки</div>
                <div class="fw-bold" style="font-size:22px;">@Model.Price.ToString("C0", new System.Globalization.CultureInfo("bg-BG"))</div>
                <div class="text-muted" style="font-size:11px;">на човек</div>
            </div>
            <div class="d-flex gap-2">
                @if (ViewData["HideDetails"] == null)
                {
                    <a asp-controller="Trips" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Детайли</a>
                }
                @if (User.Identity!.IsAuthenticated)
                {
                    <a asp-controller="Reservation" asp-action="Create" asp-route-tripId="@Model.Id" class="btn btn-danger btn-sm">Резервирай</a>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-danger btn-sm">Резервирай</a>
                }
            </div>
        </div>
    </div>
</div>