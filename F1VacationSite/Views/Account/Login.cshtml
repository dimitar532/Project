@model F1VacationSite.View_Models.LoginViewModel

@{
    ViewData["Title"] = "Вход";
}

<div class="f1-form-card">
    <h2>Добре дошъл</h2>
    <p class="form-subtitle">Влез в своя акаунт.</p>

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size:13px;"></div>

        <div class="mb-3">
            <label class="form-label">Имейл</label>
            <input asp-for="Email" class="form-control" placeholder="example@mail.com" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label class="form-label">Парола</label>
            <input asp-for="Password" class="form-control" placeholder="••••••••" />
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>
        <div class="mb-3 d-flex align-items-center gap-2">
            <input type="checkbox" name="RememberMe" class="form-check-input mt-0" style="accent-color:#e10600;" />
            <label class="form-label mb-0" style="font-size:13px;color:#666;">Запомни ме</label>
        </div>

        <button type="submit" class="btn-f1-submit">Вход</button>
        <div class="f1-form-divider">Нямаш акаунт?</div>
        <div class="text-center">
            <a asp-action="Register" class="f1-form-link">Регистрирай се безплатно</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}