@model F1VacationSite.Models.Trip

@{
    ViewData["Title"] = "Детайли";
    ViewData["HideDetails"] = true;
}

<div class="container my-4" style="max-width:800px;">
    @await Html.PartialAsync("TripPartial", Model)

    @if (!string.IsNullOrEmpty(Model.Description))
    {
        <div class="card border shadow-sm mt-3 p-4" style="border-radius:12px;">
            <h6 class="fw-semibold mb-2">За тази ваканция</h6>
            <p class="text-muted mb-0" style="font-size:14px;line-height:1.7;">@Model.Description</p>
        </div>
    }

    @if (Model.Reviews != null && Model.Reviews.Count > 0)
    {
        var total = 0;
        foreach (var r in Model.Reviews) { total += r.Rating; }
        var avgRating = (int)Math.Round((double)total / Model.Reviews.Count);

        <div class="card border shadow-sm mt-3 p-4" style="border-radius:12px;">
            <h6 class="fw-semibold mb-3">
                Отзиви
                <span class="text-muted fw-normal" style="font-size:13px;">
                    — среден рейтинг:
                    <span style="color:#f5a623;">
                        @for (int i = 0; i < avgRating; i++)
                        {
                            <text>&#9733;</text>
                        }
                    </span>
                    (@Model.Reviews.Count)
                </span>
            </h6>
            @foreach (var review in Model.Reviews)
            {
                <div class="border-bottom pb-2 mb-2">
                    <div style="color:#f5a623;font-size:13px;">
                        @for (int i = 0; i < review.Rating; i++)
                        {
                            <text>&#9733;</text>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(review.Comment))
                    {
                        <p class="text-muted mb-0" style="font-size:13px;">@review.Comment</p>
                    }
                </div>
            }
        </div>
    }

    @if (User.Identity!.IsAuthenticated)
    {
        <div class="card border shadow-sm mt-3 p-4" style="border-radius:12px;">
            <h6 class="fw-semibold mb-3">Остави отзив</h6>
            <form asp-controller="Review" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="tripId" value="@Model.Id" />
                <div class="mb-3">
                    <label class="form-label" style="font-size:13px;font-weight:500;">Рейтинг</label>
                    <select name="rating" class="form-select" style="max-width:150px;">
                        <option value="5">★★★★★</option>
                        <option value="4">★★★★</option>
                        <option value="3">★★★</option>
                        <option value="2">★★</option>
                        <option value="1">★</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label" style="font-size:13px;font-weight:500;">Коментар (по желание)</label>
                    <textarea name="comment" class="form-control" rows="3" placeholder="Сподели мнението си..."></textarea>
                </div>
                <button type="submit" class="btn btn-danger btn-sm">Изпрати</button>
            </form>
        </div>
    }

    <div class="d-flex gap-2 mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&#8592; Назад към пакети</a>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm">Редактирай</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Изтрий</a>
        }
    </div>
</div>